<Window x:Class="dvmconsole.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="About"
        SizeToContent="Height"
        MinHeight="320"
        Width="500"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Style="{StaticResource MaterialDesignWindow}"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        Icon="/dvmconsole;component/Assets/AppIcon.ico">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal">
            <Image Source="/dvmconsole;component/Assets/AppIcon.ico"
                   Width="48"
                   Height="48"
                   Margin="0,0,12,0"/>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="Digital Voice Modem"
                           FontSize="20"
                           FontWeight="Bold"/>
                <TextBlock Text="Desktop Dispatch Console"
                           FontSize="14"
                           Opacity="0.85"/>
            </StackPanel>
        </StackPanel>

        <Border Grid.Row="2"
                Padding="16"
                CornerRadius="8"
                Background="{DynamicResource MaterialDesignCardBackground}">
            <StackPanel>

                <TextBlock Text="Version Information"
               FontSize="16"
               FontWeight="SemiBold"
               Margin="0,0,0,12"/>

                <TextBlock x:Name="txtVersion"
               Margin="0,0,0,10"
               TextWrapping="Wrap"/>

                <Separator Margin="0,8,0,8"/>

                <TextBlock Text="License"
               FontWeight="SemiBold"
               Margin="0,0,0,4"/>

                <TextBlock TextWrapping="Wrap">
        This software is licensed under the 
        <Hyperlink NavigateUri="https://opensource.org/licenses/AGPL-3.0"
                   RequestNavigate="LicenseLink_Click">
            GNU Affero General Public License v3 (AGPLv3)
        </Hyperlink>.
                </TextBlock>

            </StackPanel>
        </Border>

        <StackPanel Grid.Row="4"
            Orientation="Horizontal"
            HorizontalAlignment="Right">
            <Button Content="Repository"
            Width="100"
            Height="32"
            Margin="0,0,8,0"
            Click="Repository_Click"
            Style="{StaticResource MaterialDesignRaisedButton}" />

            <Button Content="Close"
            Width="90"
            Height="32"
            Click="Close_Click"
            Style="{StaticResource MaterialDesignRaisedButton}" />
        </StackPanel>
    </Grid>
</Window>